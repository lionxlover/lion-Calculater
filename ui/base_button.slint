// ═══════════════════════════════════════════════════════════════════════════

import { LT } from "tokens.slint";

// ── BaseButton (programmer base selectors) ─────────────────────────────────
export component BaseButton inherits Rectangle {
    in property <string> lbl:    "";
    in property <bool>   active: false;
    callback clicked();

    width: 55px;
    height: 55px;
    border-radius: LT.r-btn;
    border-width: 1px;
    border-color: root.active ? LT.bdr-act : LT.bdr;
    background: root.active ? #1a2848 : ta.has-hover ? LT.btn-hov : LT.btn;
    animate background   { duration: LT.dur-fast; }
    animate border-color { duration: LT.dur-fast; }

    ta := TouchArea { clicked => { root.clicked(); } }
    Text {
        text: root.lbl;
        color: root.active ? LT.t-op : LT.t-mut;
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
