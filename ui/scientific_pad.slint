// ═══════════════════════════════════════════════════════════════════════════
//  Lion Calculator  ·  scientific_pad.slint
//  LionOS Design System  ·  Rust + Slint 1.17
// ═══════════════════════════════════════════════════════════════════════════

import { LT } from "tokens.slint";
import { CalcButton } from "calc_button.slint";

// ── ScientificPad ──────────────────────────────────────────────────────────
export component ScientificPad {
    callback button-pressed(string);
    GridLayout {
        spacing: LT.gap;
        padding: LT.pad;

        Row {
            CalcButton { lbl: "sin"; fs: 16px; clicked => { root.button-pressed("sin"); } }
            CalcButton { lbl: "cos"; fs: 16px; clicked => { root.button-pressed("cos"); } }
            CalcButton { lbl: "tan"; fs: 16px; clicked => { root.button-pressed("tan"); } }
            CalcButton { lbl: "AC";  fg: LT.t-dn; clicked => { root.button-pressed("AC"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/delete-left.svg"); fg: LT.t-dn; clicked => { root.button-pressed("⌫"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/divide.svg"); fg: LT.t-op; clicked => { root.button-pressed("÷"); } }
        }

        Row {
            CalcButton { lbl: "log"; fs: 16px; clicked => { root.button-pressed("log"); } }
            CalcButton { lbl: "ln";            clicked => { root.button-pressed("ln");  } }
            CalcButton { has-icon: true; icon: @image-url("svg/square-root-variable.svg"); clicked => { root.button-pressed("√x"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/7.svg"); clicked => { root.button-pressed("7"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/8.svg"); clicked => { root.button-pressed("8"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/9.svg"); clicked => { root.button-pressed("9"); } }
        }

        Row {
            CalcButton { lbl: "π"; clicked => { root.button-pressed("π"); } }
            CalcButton { lbl: "e"; clicked => { root.button-pressed("e"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/superscript.svg"); clicked => { root.button-pressed("xʸ"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/4.svg"); clicked => { root.button-pressed("4"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/5.svg"); clicked => { root.button-pressed("5"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/6.svg"); clicked => { root.button-pressed("6"); } }
        }

        Row {
            CalcButton { lbl: "x!";  fs: 16px; clicked => { root.button-pressed("x!"); } }
            CalcButton { lbl: "RND"; fs: 14px; clicked => { root.button-pressed("RND"); } }
            CalcButton { lbl: "1/x"; fs: 16px; clicked => { root.button-pressed("1/x"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/1.svg"); clicked => { root.button-pressed("1"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/2.svg"); clicked => { root.button-pressed("2"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/3.svg"); clicked => { root.button-pressed("3"); } }
        }

        Row {
            CalcButton { colspan: 2; cols: 2; has-icon: true; icon: @image-url("svg/xmark.svg"); fg: LT.t-op; clicked => { root.button-pressed("×"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/minus.svg"); fg: LT.t-op; clicked => { root.button-pressed("−"); } }
            CalcButton { has-icon: true; icon: @image-url("svg/0.svg"); clicked => { root.button-pressed("0"); } }
            CalcButton { lbl: "."; clicked => { root.button-pressed("."); } }
            CalcButton { has-icon: true; icon: @image-url("svg/plus.svg"); fg: LT.t-op; clicked => { root.button-pressed("+"); } }
        }

        Row {
            CalcButton { colspan: 2; cols: 2; has-icon: true; icon: @image-url("svg/percent.svg"); fg: LT.t-op; clicked => { root.button-pressed("%"); } }
            CalcButton {
                colspan: 4; cols: 4;
                has-icon: true; icon: @image-url("svg/equals.svg");
                fg: #ffffff;
                bg: LT.eq; hov: LT.eq-hov; prs: LT.eq-prs;
                clicked => { root.button-pressed("="); }
            }
        }
    }
}
